/*
========================================================================================
    RNA-Seq Neoantigen Discovery Pipeline — nextflow.config
========================================================================================
*/

params {
    // ── Input / Output ────────────────────────────────────────────────────────
    reads           = null
    outdir          = "results"
    genome          = "null  // set your reference path: Mus_musculus.GRCm39.dna.primary_assembly.fa"
    genome_fai      = "${params.genome}.fai"
    genome_dict     = "null  // set your reference path: Mus_musculus.GRCm39.dna.primary_assembly.dict"
    star_index      = "null  // set your reference path: star_index"

    // ── Runtime flags ─────────────────────────────────────────────────────────
    use_parabricks  = false           // set true when GPU node available

    // ── QC ────────────────────────────────────────────────────────────────────
    trim_adapters   = "TruSeq3-PE-2.fa"
    trim_leading    = 3
    trim_trailing   = 3
    trim_slidingwindow = "4:15"
    trim_minlen     = 36

    // ── Variant Filtering (GATK hard-filter) ─────────────────────────────────
    qual_threshold  = 30
    dp_threshold    = 10

    // ── Neoantigen Prediction — NetMHCpan-4.1 ────────────────────────────────
    mhc_alleles     = "H-2-Kb,H-2-Db"          // MHC-I murine alleles only
    peptide_lengths = "8,9,10,11"               // standard MHC-I lengths
    peptide_flank   = 13                         // AA flank around mutation site
    el_rank_cutoff  = 2.0                        // %EL Rank threshold (strong binder ≤ 0.5, weak ≤ 2.0)
    ba_rank_cutoff  = 2.0                        // %BA Rank threshold (~500 nM IC50 equivalent)
}

// ── Profiles ──────────────────────────────────────────────────────────────────
profiles {

    docker {
        docker.enabled         = true
        docker.runOptions      = '-u $(id -u):$(id -g)'
        singularity.enabled    = false
    }

    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        docker.enabled         = false
    }

    gcp {
        process.executor       = 'google-batch'
        google.project         = 'your-gcp-project'
        google.location        = 'europe-west2'
        google.batch.bootDiskSize = '50.GB'
        workDir                = 'gs://your-bucket/nextflow-work'
    }

    hpc {
        process.executor       = 'slurm'
        process.queue          = 'compute'
        process.clusterOptions = '--account=your-hpc-account'
    }

    test {
        params.reads            = "${projectDir}/test_data/*_R{1,2}.fastq.gz"
        params.genome           = "${projectDir}/test_data/GRCm39_chr19_test.fa"
        params.genome_fai       = "${projectDir}/test_data/GRCm39_chr19_test.fa.fai"
        params.genome_dict      = "${projectDir}/test_data/GRCm39_chr19_test.dict"
        params.star_index       = "${projectDir}/test_data/star_index"
        params.outdir           = "test_results"
        params.use_parabricks   = false
    }
}

// ── Default process resources ─────────────────────────────────────────────────
process {
    cpus   = 4
    memory = '16.GB'
    time   = '4.h'

    withName: 'FASTQC'           { cpus = 2;  memory = '4.GB';  time = '1.h'  }
    withName: 'TRIMMOMATIC'      { cpus = 8;  memory = '8.GB';  time = '2.h'  }
    withName: 'STAR_ALIGN'       { cpus = 16; memory = '64.GB'; time = '4.h'  }
    withName: 'PARABRICKS_FQ2BAM'{ cpus = 8;  memory = '64.GB'; time = '2.h'; accelerator = [request: 1, type: 'nvidia-tesla-a100'] }
    withName: 'STRELKA2_SOMATIC' { cpus = 8;  memory = '32.GB'; time = '4.h'  }
    withName: 'GATK_FILTRATION'  { cpus = 4;  memory = '16.GB'; time = '2.h'  }
    withName: 'VEP_ANNOTATE'     { cpus = 8;  memory = '32.GB'; time = '4.h'  }
    withName: 'NEOANTIGEN_PREDICT' { cpus = 4; memory = '16.GB'; time = '2.h'  }
    withName: 'NETMHCPAN'         { cpus = 8; memory = '16.GB'; time = '4.h'  }
}

// ── Reporting ─────────────────────────────────────────────────────────────────
timeline { enabled = true; file = "${params.outdir}/pipeline_info/timeline.html" }
report   { enabled = true; file = "${params.outdir}/pipeline_info/report.html"   }
trace    { enabled = true; file = "${params.outdir}/pipeline_info/trace.txt"     }
dag      { enabled = true; file = "${params.outdir}/pipeline_info/dag.svg"       }

manifest {
    name        = 'pOSNode/rna-neoantigen-pipeline'
    author      = 'Owais Siddiqi'
    description = 'RNA-Seq somatic variant calling and MHC-I neoantigen prediction — GRCm39'
    version     = '1.0.0'
    nextflowVersion = '>=23.04.0'
}
